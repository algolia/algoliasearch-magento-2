parameters:
    level: 1
    reportUnmatchedIgnoredErrors: false
    paths:
        - Api
        - Block
        - Controller
        - DataProvider
        - Exception
        - Factory
        - Helper
        - Model
        - Plugin
        - Setup
        - Test
        - Ui
        - ViewModel
        - registration.php
    ignoreErrors:
        - '#Call to static method getObjectManager\(\) on an unknown class Magento\\TestFramework\\Helper\\Bootstrap.#'
